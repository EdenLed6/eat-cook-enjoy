# Database (Neon free tier)
DATABASE_URL=postgres://user:pass@ep-xxx.eu-central-1.aws.neon.tech/eat?sslmode=require

# Anthropic API
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL_DEFAULT=claude-sonnet-4-6
ANTHROPIC_MODEL_HEAVY=claude-opus-4-7

# WhatsApp owner (E.164 format, no +)
OWNER_PHONE_E164=972501234567

# Tavily web search
TAVILY_API_KEY=tvly-...

# Cloudflare R2 (S3-compatible)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=eat-cook-enjoy
R2_PUBLIC_URL=https://pub-xxx.r2.dev

# Resend (email magic link)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=login@yourdomain.com

# App
APP_URL=https://eat-cook-enjoy.fly.dev
DASHBOARD_OWNER_EMAIL=eden@example.com
SESSION_SECRET=replace-with-random-32+chars
TZ=Asia/Jerusalem

# HMAC secret for /api/steps from companion app
STEPS_HMAC_SECRET=replace-with-random-32+chars

# Logging (optional)
BETTERSTACK_TOKEN=
LOG_LEVEL=info
