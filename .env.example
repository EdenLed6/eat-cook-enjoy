# Supabase Postgres (Transaction pooler URL from Supabase dashboard → Connect → Pooler)
# Format: postgresql://postgres.{ref}:{password}@aws-0-{region}.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.lgrfaijexfotubdylxky:YOUR_DB_PASSWORD@aws-0-eu-west-3.pooler.supabase.com:6543/postgres

# Supabase API
SUPABASE_URL=https://lgrfaijexfotubdylxky.supabase.co
SUPABASE_ANON_KEY=eyJhbGci...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...
SUPABASE_STORAGE_BUCKET=eat-cook-enjoy

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL_DEFAULT=claude-sonnet-4-6
ANTHROPIC_MODEL_HEAVY=claude-opus-4-7

# WhatsApp owner (E.164 format, no +)
