{
  "name": "eat-cook-enjoy",
  "version": "0.1.0",
  "private": true,
  "description": "Personal WhatsApp fitness/nutrition agent + web dashboard",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.10.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev:worker": "pnpm --filter @eat/whatsapp-worker dev",
    "dev:web": "pnpm --filter @eat/web dev",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "db:generate": "pnpm --filter @eat/db generate",
    "db:push": "pnpm --filter @eat/db push",
    "db:studio": "pnpm --filter @eat/db studio"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "typescript": "^5.6.3",
    "tsx": "^4.19.2",
    "vitest": "^2.1.5",
    "eslint": "^9.14.0",
    "prettier": "^3.3.3"
  }
}
